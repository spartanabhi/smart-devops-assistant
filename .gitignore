.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, lock file can be reason of failures.
#   Pipfile.lock

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pypa/pip
__pypackages__/

